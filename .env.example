# ── Engram ──────────────────────────────────────────────────────────────────
# LOCAL DEV needs nothing here — Engram has sane defaults and the dashboard is OPEN
# until you set AUTH_SECRET. Copy to .env.local only if you want to override a default.
#
# FOR DEPLOY set the five bootstrap vars below on your host (they gate login + say where
# state lives, so they can't be configured from inside the app). EVERYTHING ELSE is set
# in the dashboard → Settings, with no redeploy — see the commented reference at the bottom.
# Full guide: DEPLOY.md.

# ── Production bootstrap (set these on your host) ─────────────────────────────
AUTH_SECRET=""            # openssl rand -base64 32 (or Railway "Generate"). Empty => dashboard OPEN — local only.
APP_URL=""                # public base URL, e.g. https://your-app.up.railway.app (Google OAuth redirect base). On Railway: https://${{RAILWAY_PUBLIC_DOMAIN}}
ALLOWED_EMAILS=""         # comma-separated Google emails allowed to sign in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Where app state + vault clones live. REQUIRED on a host with a volume (e.g. Railway),
# or your data is ephemeral and lost on redeploy. Point it at the mounted volume.
# ENGRAM_DATA_DIR="/data"

# ── Optional — configure in the dashboard → Settings (no redeploy) ────────────
# Listed for reference only. Uncomment to hard-set via env instead of the UI; a value
# saved in Settings overrides the env value either way.
#
# NEXT_PUBLIC_APP_NAME="Engram"            # display name (sidebar + browser tab)
# GIT_SYNC_ENABLED="false"                 # auto commit + push the active vault
# GIT_AUTHOR_NAME="Engram"
# GIT_AUTHOR_EMAIL="brain@example.com"
# GITHUB_CLIENT_ID=""                      # "Connect GitHub" repo flow (URL+token path needs no OAuth app)
# GITHUB_CLIENT_SECRET=""
# HARNESS_ENABLED="false"                  # brain_capture auto-filing (costs Anthropic tokens)
# ANTHROPIC_API_KEY=""
# CAPTURE_MODEL="claude-haiku-4-5-20251001"
# MCP_TOKEN=""                             # one shared MCP key; or create per-teammate tokens on the Connect page
# ENGRAM_STATE_DIR="/data/.engram"         # override where token hashes persist (defaults to ENGRAM_DATA_DIR)
# VAULT_DIR="/data"                        # fallback local vault (workspaces are normally connected in the UI)
# AUTH_DISABLED="false"                    # single-user local mode: no Google auth, MCP open. NEVER true in production.
